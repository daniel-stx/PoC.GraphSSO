      "item": [
        {
          "name": "Create local user",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayName\": \"Test User\",\n  \"mailNickname\": \"testuser\",\n  \"userPrincipalName\": \"testuser@memberportalhotelrez.onmicrosoft.com\",\n  \"password\": \"P@ssw0rd12345!\",\n  \"accountEnabled\": true,\n  \"forceChangePasswordNextSignIn\": true,\n  \"employeeId\": \"EMP-12345\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:5150/poc/user-creation/users",
